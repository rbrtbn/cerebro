#!/usr/bin/env bash
set -euo pipefail

# Run a git or gh command with the agent's GitHub identity loaded from .envrc.
#
# .envrc exposes the agent's secrets under AGENT_* names so a regular shell
# in this directory keeps the human's gh auth and git config untouched. This
# wrapper opts into the agent identity for one command at a time by remapping
# the AGENT_* variables onto the names git and gh actually read.
#
# Usage: as-agent <git|gh> [args...]

if [[ $# -eq 0 ]]; then
  echo "usage: as-agent <git|gh> [args...]" >&2
  exit 64
fi

exec direnv exec . bash -c '
  GH_TOKEN="${AGENT_GH_TOKEN:?AGENT_GH_TOKEN missing — is .envrc loaded?}" \
  GIT_AUTHOR_NAME="${AGENT_GIT_AUTHOR_NAME:?AGENT_GIT_AUTHOR_NAME missing}" \
  GIT_AUTHOR_EMAIL="${AGENT_GIT_AUTHOR_EMAIL:?AGENT_GIT_AUTHOR_EMAIL missing}" \
  GIT_COMMITTER_NAME="${AGENT_GIT_COMMITTER_NAME:?AGENT_GIT_COMMITTER_NAME missing}" \
  GIT_COMMITTER_EMAIL="${AGENT_GIT_COMMITTER_EMAIL:?AGENT_GIT_COMMITTER_EMAIL missing}" \
  exec "$@"
' bash "$@"
